@page "/register"
@inject IConfiguration Configuration
@inject NavigationManager Navigation

<PageTitle>Register - BookStore</PageTitle>

<MudContainer MaxWidth="MaxWidth.Small" Class="mt-8">
    <MudPaper Elevation="4" Class="pa-8" Style="border-radius: 12px;">
        <MudText Typo="Typo.h5" Align="Align.Center">Redirecting to account registration...</MudText>
        <MudProgressCircular Class="mt-4" Color="Color.Primary" Indeterminate="true" />
    </MudPaper>
</MudContainer>

@code {
    protected override void OnInitialized()
    {
        var keycloakBaseUrl = Configuration[$"services:{BookStore.ServiceDefaults.ResourceNames.Keycloak}:https:0"]
            ?? Configuration[$"services:{BookStore.ServiceDefaults.ResourceNames.Keycloak}:http:0"];

        if (string.IsNullOrWhiteSpace(keycloakBaseUrl))
        {
            Navigation.NavigateTo("/login/oidc", forceLoad: true);
            return;
        }

        var callbackUri = Navigation.ToAbsoluteUri("/signin-oidc").ToString();
        var registrationUrl =
            $"{keycloakBaseUrl.TrimEnd('/')}/realms/bookstore/protocol/openid-connect/registrations" +
            $"?client_id=bookstore-web&response_type=code&redirect_uri={Uri.EscapeDataString(callbackUri)}";

        Navigation.NavigateTo(registrationUrl, forceLoad: true);
    }
}
