
@page "/register"
@using BookStore.Web.Components.Auth
@using BookStore.Web.Services
@inject AuthenticationService AuthService
@inject PasskeyService PasskeyService
@inject JwtAuthenticationStateProvider AuthStateProvider
@inject NavigationManager Navigation
@inject IJSRuntime JS
@inject ErrorLocalizationService ErrorLocalizer

<PageTitle>Register - BookStore</PageTitle>

<section class="auth-shell">
    <article class="auth-card">
        <h1>Create Account</h1>

        @if (!string.IsNullOrEmpty(errorMessage))
        {
            <AlertBanner Message="@errorMessage" Severity="AlertBanner.AlertSeverity.Error" />
        }

        @if (registrationSuccess && requiresVerification)
        {
            <AlertBanner Message="Registration successful. Check your email to verify your account." Severity="AlertBanner.AlertSeverity.Success" />
        }

        @if (registrationSuccess && !requiresVerification)
        {
            <AlertBanner Message="Registration successful. Redirecting..." Severity="AlertBanner.AlertSeverity.Success" />
        }

        <div class="tabs">
            <section class="tab-panel">
                <h3>Standard</h3>
                <label class="form-label" for="register-email">Email</label>
                <input id="register-email" class="form-input" type="email" @bind="email" />

                <PasswordField Id="register-password" Label="Password" Value="@password" ValueChanged="@(value => password = value)" />
                <PasswordStrengthHints Password="@password" />
                <PasswordField Id="register-confirm" Label="Confirm Password" Value="@confirmPassword" ValueChanged="@(value => confirmPassword = value)" />

                <button class="btn btn-primary" @onclick="HandleRegister" disabled="@isLoading">
                    @(isLoading ? "Creating account..." : "Register")
                </button>
            </section>

            <section class="tab-panel">
                <h3>Passkey</h3>
                <p class="text-muted">Create an account with Face ID, Touch ID, or a security key.</p>
                <button class="btn btn-ghost" @onclick="RegisterWithPasskey" disabled="@isLoading">Register with Passkey</button>
            </section>
        </div>

        <p>Already have an account? <a href="/login">Sign in</a></p>
    </article>
</section>

@code {
    private string email = string.Empty;
    private string password = string.Empty;
    private string confirmPassword = string.Empty;
    private string? errorMessage;
    private bool isLoading;
    private bool registrationSuccess;
    private bool requiresVerification;

    private async Task HandleRegister()
    {
        errorMessage = null;
        if (password != confirmPassword)
        {
            errorMessage = "Passwords do not match.";
            return;
        }

        isLoading = true;

        try
        {
            var result = await AuthService.RegisterAsync(email, password);
            if (result.IsSuccess)
            {
                registrationSuccess = true;

                if (result.Value is { AccessToken: not null } loginResponse)
                {
                    requiresVerification = false;
                    await AuthStateProvider.NotifyUserAuthentication(loginResponse.AccessToken, loginResponse.RefreshToken);
                    await JS.InvokeVoidAsync("authBroadcast.notifyLogin");
                    await Task.Delay(1000);
                    Navigation.NavigateTo("/");
                }
                else
                {
                    requiresVerification = true;
                }
            }
            else
            {
                errorMessage = ErrorLocalizer.GetLocalizedMessage(result.Error);
            }
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task RegisterWithPasskey()
    {
        errorMessage = null;
        if (string.IsNullOrWhiteSpace(email))
        {
            errorMessage = "Email is required.";
            return;
        }

        isLoading = true;
        try
        {
            var optionsResult = await PasskeyService.GetCreationOptionsAsync(email);
            if (optionsResult.IsFailure)
            {
                errorMessage = ErrorLocalizer.GetLocalizedMessage(optionsResult.Error);
                return;
            }

            var options = optionsResult.Value;
            var credentialJson = await JS.InvokeAsync<string>("passkey.register", options.OptionsJson);
            var result = await PasskeyService.RegisterPasskeyAsync(credentialJson, email, options.UserId);

            if (result.IsSuccess)
            {
                registrationSuccess = true;
                requiresVerification = true;
            }
            else
            {
                errorMessage = ErrorLocalizer.GetLocalizedMessage(result.Error);
            }
        }
        catch (Exception ex)
        {
            errorMessage = ErrorLocalizer.GetLocalizedMessage(ex.Message);
        }
        finally
        {
            isLoading = false;
        }
    }
}
