@page "/login"
@using BookStore.Web.Services
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.JSInterop
@using BookStore.Shared.Validation
@using BookStore.Shared.Models
@inject AuthenticationService AuthService
@inject TenantService TenantService
@inject PasskeyService PasskeyService
@inject JwtAuthenticationStateProvider AuthStateProvider
@inject NavigationManager Navigation
@inject IJSRuntime Js
@inject ILogger<Login> Logger
@inject ErrorLocalizationService ErrorLocalizer


<PageTitle>Login - BookStore</PageTitle>

<section class="auth-shell">
    <article class="card auth-card centered-card" style="max-width:420px;">
        <h1 class="mb-2">Sign In</h1>
        <p class="muted mb-4">Tenant: @TenantService.CurrentTenantName</p>

        @if (!string.IsNullOrEmpty(errorMessage))
        {
            <div class="alert alert-error mb-4">
                @errorMessage
                @if (showResendVerification)
                {
                    <br/>
                    <a href="#" @onclick="HandleResendVerification" @onclick:preventDefault="true" class="mt-2" style="cursor: pointer; font-weight: bold;">Resend verification email</a>
                }
            </div>
        }

        @if (!string.IsNullOrEmpty(resendMessage))
        {
            <div class="alert alert-success mb-4 text-center">@resendMessage</div>
        }

        <form @onsubmit="HandleLogin">
            <label for="email" class="form-label">Email</label>
            <input id="email" type="email" @bind="email" required placeholder="you@example.com" class="form-input mb-2" aria-label="Email Address" />
            @if (!string.IsNullOrWhiteSpace(emailValidationError))
            {
                <div class="validation-message mb-3">@emailValidationError</div>
            }

            <label for="password" class="form-label">Password</label>
            <input id="password" type="password" @bind="password" required placeholder="Enter your password" class="form-input mb-2" aria-label="Password" />
            @if (!string.IsNullOrWhiteSpace(passwordValidationError))
            {
                <div class="validation-message mb-3">@passwordValidationError</div>
            }

            <button type="submit" class="btn btn-primary" style="width:100%;" disabled="@isLoading">
                @(isLoading ? "Signing in..." : "Sign In")
            </button>
        </form>

        <div style="margin:var(--space-4) 0;">
            <label for="passkey-email" class="form-label">Passkey email (optional)</label>
            <input id="passkey-email" type="email" @bind="email" placeholder="you@example.com" autocomplete="webauthn" class="form-input mb-2" aria-label="Passkey Email Address" />
            @if (!string.IsNullOrWhiteSpace(passkeyEmailValidationError))
            {
                <div class="validation-message mb-3">@passkeyEmailValidationError</div>
            }
            <button type="button" class="btn btn-ghost" style="width:100%;" @onclick="LoginWithPasskey" disabled="@isLoading">Sign in with Passkey</button>
        </div>

        <p class="mt-2">Do not have an account? <a href="/register">Create one</a></p>
        <p class="mt-1"><a href="/account/password">Manage password</a></p>
    </article>
</section>

@code {
    private string email = string.Empty;
    private string password = string.Empty;
    private string? errorMessage;
    private BookStore.Shared.Models.Error? lastError;
    private string? resendMessage;
    private bool isLoading;
    private bool showResendVerification;
    private string? emailValidationError;
    private string? passwordValidationError;
    private string? passkeyEmailValidationError;

    [SupplyParameterFromQuery] public string? ReturnUrl { get; set; }

    private async Task HandleLogin()
    {
        resendMessage = null;
        errorMessage = null;
        showResendVerification = false;
        emailValidationError = ValidateEmail(email);
        passwordValidationError = string.IsNullOrWhiteSpace(password) ? "Password is required." : null;

        if (!string.IsNullOrWhiteSpace(emailValidationError) || !string.IsNullOrWhiteSpace(passwordValidationError))
        {
            return;
        }

        isLoading = true;
        lastError = null;

        try
        {
            Logger.LogInformation("Attempting login for {Email}", email);
            var result = await AuthService.LoginAsync(email, password);

            if (result.IsSuccess)
            {
                await AuthStateProvider.NotifyUserAuthentication(result.Value.AccessToken!, result.Value.RefreshToken);

                try
                {
                    await Js.InvokeVoidAsync("authBroadcast.notifyLogin");
                }
                catch (Exception ex)
                {
                    Logger.LogWarning(ex, "BroadcastChannel login notification failed");
                }

                Navigation.NavigateTo(ReturnUrl ?? "/");
            }
            else
            {
                HandleLoginError(result.Error);
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Login exception");
            errorMessage = ErrorLocalizer.GetLocalizedMessage(ex.Message);
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task LoginWithPasskey()
    {
        resendMessage = null;
        errorMessage = null;
        showResendVerification = false;
        passkeyEmailValidationError = ValidateOptionalEmail(email);
        if (!string.IsNullOrWhiteSpace(passkeyEmailValidationError))
        {
            return;
        }

        isLoading = true;
        lastError = null;

        try
        {
            Logger.LogInformation("Attempting passkey login");

            var optionsResult = await PasskeyService.GetLoginOptionsAsync(string.IsNullOrWhiteSpace(email) ? null : email);
            if (optionsResult.IsFailure)
            {
                HandleLoginError(optionsResult.Error);
                return;
            }

            var optionsJson = optionsResult.Value;
            if (string.IsNullOrWhiteSpace(optionsJson))
            {
                errorMessage = "Passkey options are missing.";
                return;
            }

            try
            {
                _ = System.Text.Json.JsonDocument.Parse(optionsJson);
            }
            catch
            {
                errorMessage = "Passkey options are invalid.";
                return;
            }

            var credentialJson = await Js.InvokeAsync<string>("passkey.login", optionsJson);
            var result = await PasskeyService.LoginWithPasskeyAsync(credentialJson);

            if (result.IsSuccess)
            {
                await AuthStateProvider.NotifyUserAuthentication(result.Value.AccessToken!, result.Value.RefreshToken);

                try
                {
                    await Js.InvokeVoidAsync("authBroadcast.notifyLogin");
                }
                catch (Exception ex)
                {
                    Logger.LogWarning(ex, "BroadcastChannel login notification failed");
                }

                Navigation.NavigateTo(ReturnUrl ?? "/");
            }
            else
            {
                HandleLoginError(result.Error);
            }
        }
        catch (TaskCanceledException)
        {
            errorMessage = "Login was cancelled or timed out.";
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Passkey login exception");
            var message = ex.Message;
            if (message.Contains("Error:", StringComparison.Ordinal))
            {
                var parts = message.Split("Error:", 2, StringSplitOptions.TrimEntries);
                message = parts[^1];
            }

            errorMessage = ErrorLocalizer.GetLocalizedMessage(message);
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task HandleResendVerification()
    {
        emailValidationError = null;
        if (string.IsNullOrWhiteSpace(email))
        {
            errorMessage = "Please enter your email address first.";
            return;
        }

        emailValidationError = ValidateEmail(email);
        if (!string.IsNullOrWhiteSpace(emailValidationError))
        {
            return;
        }

        isLoading = true;
        resendMessage = null;
        errorMessage = null;
        lastError = null;

        try
        {
            var result = await AuthService.ResendVerificationEmailAsync(email);
            if (result.IsSuccess)
            {
                resendMessage = "If an account exists for this email, a new verification link has been sent.";
                showResendVerification = false;
            }
            else
            {
                lastError = result.Error;
                errorMessage = ErrorLocalizer.GetLocalizedMessage(result.Error);
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Resend verification exception");
            errorMessage = "An error occurred while resending the verification email.";
        }
        finally
        {
            isLoading = false;
        }
    }

    private void HandleLoginError(BookStore.Shared.Models.Error error)
    {
        lastError = error;
        errorMessage = ErrorLocalizer.GetLocalizedMessage(error);
        showResendVerification =
            error.Code == ErrorCodes.Auth.EmailUnconfirmed ||
            error.Message?.Contains("Requires verification", StringComparison.OrdinalIgnoreCase) == true;
    }

    private static string? ValidateEmail(string value) => EmailValidator.GetError(value);

    private static string? ValidateOptionalEmail(string value)
        => string.IsNullOrWhiteSpace(value) ? null : EmailValidator.GetError(value);
}
