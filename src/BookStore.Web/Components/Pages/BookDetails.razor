@page "/book/{id:guid}"
@using BookStore.Shared.Models
@using BookStore.Client
@using BookStore.Web.Components.Catalog
@using BookStore.Web.Logging
@using BookStore.Web.Services
@using Microsoft.AspNetCore.Components.Authorization
@inject IBooksClient BooksClient
@inject IShoppingCartClient CartClient
@inject CatalogService CatalogService
@inject CurrencyService CurrencyService
@inject AuthenticationStateProvider AuthStateProvider
@inject QueryInvalidationService InvalidationService
@inject BookStoreEventsService EventsService
@inject NavigationManager Navigation
@inject ILogger<BookDetails> Logger
@inject INotificationService NotificationService
@implements IDisposable
@rendermode InteractiveServer

<PageTitle>@(book?.Title ?? "Book Details") - BookStore</PageTitle>

<section class="container mt-8">
    <div class="catalog-breadcrumbs mb-4">
        <button class="btn btn-ghost" @onclick="NavigateHome">Back to Catalog</button>
    </div>

    @if (isLoading)
    {
        <div class="catalog-skeleton-grid">
            <div class="catalog-skeleton-cover"></div>
            <div class="catalog-skeleton-body">
                <div class="catalog-skeleton-line lg"></div>
                <div class="catalog-skeleton-line"></div>
                <div class="catalog-skeleton-line"></div>
            </div>
        </div>
    }
    else if (!string.IsNullOrWhiteSpace(errorMessage))
    {
        <div class="alert-error">@errorMessage</div>
        <button class="btn btn-primary" @onclick="RetryLoad">Retry</button>
    }
    else if (book is not null)
    {
        <article class="book-detail-shell" style="display:grid;grid-template-columns:minmax(260px,360px) 1fr;gap:var(--space-8);align-items:start;">
            <div class="book-detail-cover" style="position:sticky;top:var(--space-6);">
                @if (!string.IsNullOrWhiteSpace(book.CoverImageUrl))
                {
                    <img src="@book.CoverImageUrl" alt="@book.Title" />
                }
                else
                {
                    <div class="book-detail-cover-placeholder">No cover</div>
                }
            </div>

            <div class="book-detail-content">
                <h1>@book.Title</h1>
                <p class="book-detail-authors">
                    @for (var i = 0; i < book.Authors.Count; i++)
                    {
                        var author = book.Authors[i];
                        <a href="@($"/?authorId={author.Id}")">@author.Name</a>
                        if (i < book.Authors.Count - 1)
                        {
                            <span>, </span>
                        }
                    }
                </p>

                @if (book.Publisher is not null)
                {
                    <p class="book-detail-meta">Publisher: <a href="@($"/?publisherId={book.Publisher.Id}")">@book.Publisher.Name</a></p>
                }

                @if (book.Categories.Count > 0)
                {
                    <div class="list-row" style="flex-wrap:wrap;gap:var(--space-2);margin:var(--space-3) 0;">
                        @foreach (var category in book.Categories)
                        {
                            <a class="badge" href="@($"/?categoryId={category.Id}")">@category.Name</a>
                        }
                    </div>
                }

                @if (book.PublicationDate.HasValue)
                {
                    <p class="book-detail-meta">Published: @book.PublicationDate.Value:yyyy-MM-dd</p>
                }

                @if (!string.IsNullOrWhiteSpace(book.Isbn))
                {
                    <p class="book-detail-meta">ISBN: @book.Isbn</p>
                }

                @if (!string.IsNullOrWhiteSpace(book.LanguageName))
                {
                    <p class="book-detail-meta">Language: @book.LanguageName</p>
                }

                <div class="book-detail-price">
                    @if (book.ActiveSale is not null && book.Prices is not null && book.Prices.TryGetValue(CurrencyService.CurrentCurrency, out var originalPrice))
                    {
                        var salePrice = book.ActiveSale.Value.CalculateDiscountedPrice(originalPrice);
                        <span class="old">@CurrencyService.FormatPrice(originalPrice)</span>
                        <span class="new">@CurrencyService.FormatPrice(salePrice)</span>
                        <BookSaleBadge Sale="@book.ActiveSale" />
                    }
                    else
                    {
                        <span class="new">@CurrencyService.FormatPrice(book.Prices)</span>
                    }
                </div>

                <div class="book-detail-actions">
                    <AuthorizeView>
                        <Authorized>
                            <label class="field-label" for="qty">Quantity</label>
                            <input id="qty" class="input-field" type="number" min="1" max="99" @bind="quantity" />
                            <button class="btn btn-primary" @onclick="AddToCartAsync">Add To Cart</button>
                            <FavoriteButton BookId="@book.Id" IsFavorite="@book.IsFavorite" ETag="@book.ETag" OnToggled="OnFavoriteToggled" />
                            <div class="book-detail-rating">
                                <StarRating Value="@book.UserRating" Editable="true" OnRatingChanged="RateBookAsync" />

                                @if (book.UserRating > 0)
                                {
                                    <button class="btn btn-ghost" @onclick="ClearRatingAsync">Clear Rating</button>
                                }
                            </div>
                        </Authorized>
                    </AuthorizeView>

                    <div class="book-detail-rating" style="margin-top:var(--space-3);">
                        <span>Average rating: @book.AverageRating.ToString("F1") (@book.RatingCount)</span>
                    </div>

                    <AuthorizeView Roles="Admin">
                        <Authorized>
                            @if (!book.IsDeleted)
                            {
                                <button class="btn btn-ghost" @onclick="SoftDeleteAsync">Delete Book</button>
                            }
                            else
                            {
                                <button class="btn btn-primary" @onclick="RestoreAsync">Restore Book</button>
                            }
                        </Authorized>
                    </AuthorizeView>
                </div>

                @if (!string.IsNullOrWhiteSpace(book.Description))
                {
                    <p class="book-detail-description">@book.Description</p>
                }

                @if (_relatedBooks?.Any() == true)
                {
                    <section style="margin-top:var(--space-8);">
                        <h2>Related Books</h2>
                        <BookGrid>
                            @foreach (var related in _relatedBooks)
                            {
                                <BookCard Book="related" OnViewDetails="@(() => NavigateToBook(related.Id))" />
                            }
                        </BookGrid>
                    </section>
                }
            </div>
        </article>
    }
</section>

@code {
    [Parameter] public Guid Id { get; set; }

    private ReactiveQuery<BookDto?>? bookQuery;
    private List<BookDto>? _relatedBooks;
    private BookDto? book => bookQuery?.Data;
    private string? errorMessage => bookQuery?.Error;
    private bool isLoading => bookQuery?.IsLoading ?? true;
    private readonly CancellationTokenSource _cts = new();
    private int quantity = 1;

    protected override async Task OnInitializedAsync()
    {
        EventsService.StartListening();

        bookQuery = new ReactiveQuery<BookDto?>(
            queryFn: async ct => await BooksClient.GetBookAsync(Id, cancellationToken: ct),
            eventsService: EventsService,
            invalidationService: InvalidationService,
            queryKeys: new[] { $"Book:{Id}", "Books" },
            onStateChanged: () => InvokeAsync(StateHasChanged),
            logger: Logger);

        await bookQuery.LoadAsync(cancellationToken: _cts.Token);
        await LoadRelatedBooksAsync(_cts.Token);
        CurrencyService.OnCurrencyChanged += StateHasChanged;
    }

    private async Task LoadRelatedBooksAsync(CancellationToken cancellationToken)
    {
        if (book is null || book.Categories.Count == 0)
        {
            _relatedBooks = [];
            return;
        }

        var categoryId = book.Categories[0].Id;
        var relatedResponse = await BooksClient.GetBooksAsync(new BookSearchRequest
        {
            CategoryId = categoryId,
            Page = 1,
            PageSize = 6
        }, cancellationToken);

        _relatedBooks = relatedResponse.Items.Where(x => x.Id != Id).Take(4).ToList();
    }

    private async Task AddToCartAsync()
    {
        if (book is null) return;

        try
        {
            await CartClient.AddToCartAsync(new AddToCartClientRequest(book.Id, quantity), _cts.Token);
            NotificationService.Add("Book added to cart", NotificationSeverity.Success);
        }
        catch (Exception ex)
        {
            Log.BookDetailsAddToCartFailed(Logger, book.Id, ex);
            NotificationService.Add("Unable to add book to cart", NotificationSeverity.Error);
        }
    }

    private Task OnFavoriteToggled(bool isFavorite)
    {
        if (book is null)
        {
            return Task.CompletedTask;
        }

        bookQuery?.MutateData(b => b is null
            ? null
            : b with
            {
                IsFavorite = isFavorite,
                LikeCount = isFavorite ? b.LikeCount + 1 : Math.Max(0, b.LikeCount - 1)
            });

        return Task.CompletedTask;
    }

    private async Task RateBookAsync(int stars)
    {
        if (book is null) return;

        await CatalogService.RateBookAsync(
            book,
            stars,
            setOptimistic: rating => bookQuery?.MutateData(b => b is null ? null : b with { UserRating = rating }),
            setRollback: rating => bookQuery?.MutateData(b => b is null ? null : b with { UserRating = rating }),
            cancellationToken: _cts.Token);
    }

    private async Task ClearRatingAsync()
    {
        if (book is null) return;

        await CatalogService.RemoveRatingAsync(
            book,
            setOptimistic: () => bookQuery?.MutateData(b => b is null ? null : b with { UserRating = 0 }),
            setRollback: rating => bookQuery?.MutateData(b => b is null ? null : b with { UserRating = rating }),
            cancellationToken: _cts.Token);
    }

    private async Task ToggleFavoriteAsync(BookDto bookToToggle)
    {
        await CatalogService.ToggleFavoriteAsync(
            bookToToggle,
            setOptimistic: newState => bookQuery?.MutateData(b => b is null ? null : b with
            {
                IsFavorite = newState,
                LikeCount = newState ? b.LikeCount + 1 : b.LikeCount - 1
            }),
            setRollback: oldState => bookQuery?.MutateData(b => b is null ? null : b with
            {
                IsFavorite = oldState,
                LikeCount = oldState ? b.LikeCount + 1 : b.LikeCount - 1
            }),
            cancellationToken: _cts.Token);
    }

    private async Task SoftDeleteAsync()
    {
        if (book is null) return;

        try
        {
            await BooksClient.SoftDeleteBookAsync(book.Id, cancellationToken: _cts.Token);
        }
        catch (Exception ex)
        {
            Log.BookDetailsSoftDeleteFailed(Logger, book.Id, ex);
        }
    }

    private async Task RestoreAsync()
    {
        if (book is null) return;

        try
        {
            await BooksClient.RestoreBookAsync(book.Id, cancellationToken: _cts.Token);
        }
        catch (Exception ex)
        {
            Log.BookDetailsRestoreFailed(Logger, book.Id, ex);
        }
    }

    private async Task RetryLoad()
    {
        if (bookQuery is null) return;
        await bookQuery.LoadAsync(cancellationToken: _cts.Token);
        await LoadRelatedBooksAsync(_cts.Token);
    }

    private void NavigateToBook(Guid bookId) => Navigation.NavigateTo($"/book/{bookId}");

    private void NavigateHome() => Navigation.NavigateTo("/");

    public void Dispose()
    {
        _cts.Cancel();
        _cts.Dispose();
        bookQuery?.Dispose();
        CurrencyService.OnCurrencyChanged -= StateHasChanged;
    }
}
