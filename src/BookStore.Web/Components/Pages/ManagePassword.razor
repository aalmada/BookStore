@page "/account/password"
@using Microsoft.AspNetCore.Authorization
@using BookStore.Web.Components.Auth
@using BookStore.Web.Services
@attribute [Authorize]
@inject AuthenticationService AuthService
@inject PasskeyService PasskeyService
@inject INotificationService NotificationService
@inject ErrorLocalizationService ErrorLocalizer

<PageTitle>Manage Password - BookStore</PageTitle>

<section class="auth-shell">
    <article class="card auth-card centered-card" style="max-width:760px;">
        <h1>Account Security</h1>

        @if (_hasPassword is null || _hasPasskeys is null)
        {
            <LoadingSpinner IsVisible="true" Message="Loading account security" />
        }
        else if (_hasPassword == false)
        {
            <AlertBanner Message="You do not have a password yet. Set one as a backup sign-in method."
                         Severity="AlertBanner.AlertSeverity.Info" />
            <PasswordField Id="add-password" Label="New Password" Value="@_newPassword" ValueChanged="@(value => _newPassword = value)" />
            <PasswordStrengthHints Password="@_newPassword" />
            <PasswordField Id="add-password-confirm" Label="Confirm Password" Value="@_confirmPassword" ValueChanged="@(value => _confirmPassword = value)" />
            <button class="btn btn-primary" @onclick="SetPasswordAsync" disabled="@_isLoading">Set Password</button>
        }
        else
        {
            <PasswordField Id="current-password" Label="Current Password" Value="@_currentPassword" ValueChanged="@(value => _currentPassword = value)" />
            <PasswordField Id="new-password" Label="New Password" Value="@_newPassword" ValueChanged="@(value => _newPassword = value)" />
            <PasswordStrengthHints Password="@_newPassword" />
            <PasswordField Id="confirm-password" Label="Confirm New Password" Value="@_confirmPassword" ValueChanged="@(value => _confirmPassword = value)" />
            <button class="btn btn-primary" @onclick="ChangePasswordAsync" disabled="@_isLoading">Change Password</button>
            @if (_hasPasskeys == true)
            {
                <button class="btn btn-ghost" @onclick="RemovePasswordAsync" disabled="@_isLoading">Remove Password</button>
            }
            else
            {
                <AlertBanner Message="Add a passkey before removing password-based sign in." Severity="AlertBanner.AlertSeverity.Warning" />
            }
        }
    </article>
</section>

@code {
    private bool? _hasPassword;
    private bool? _hasPasskeys;
    private bool _isLoading;
    private string _currentPassword = string.Empty;
    private string _newPassword = string.Empty;
    private string _confirmPassword = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        var hasPasswordTask = AuthService.HasPasswordAsync();
        var passkeysTask = PasskeyService.ListPasskeysAsync();
        await Task.WhenAll(hasPasswordTask, passkeysTask);
        _hasPassword = hasPasswordTask.Result;
        _hasPasskeys = passkeysTask.Result.Any();
    }

    private bool IsFormInvalid()
    {
        if (string.IsNullOrWhiteSpace(_newPassword) || _newPassword != _confirmPassword)
        {
            NotificationService.Add("Passwords must match.", NotificationSeverity.Warning);
            return true;
        }

        return false;
    }

    private async Task SetPasswordAsync()
    {
        if (IsFormInvalid()) return;
        _isLoading = true;
        try
        {
            var result = await AuthService.AddPasswordAsync(_newPassword);
            NotificationService.Add(result.IsSuccess ? "Password set successfully." : ErrorLocalizer.GetLocalizedMessage(result.Error) ?? "Failed to set password.", result.IsSuccess ? NotificationSeverity.Success : NotificationSeverity.Error);
            if (result.IsSuccess)
            {
                _hasPassword = true;
                _newPassword = string.Empty;
                _confirmPassword = string.Empty;
            }
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task ChangePasswordAsync()
    {
        if (IsFormInvalid()) return;
        _isLoading = true;
        try
        {
            var result = await AuthService.ChangePasswordAsync(_currentPassword, _newPassword);
            NotificationService.Add(result.IsSuccess ? "Password changed successfully." : ErrorLocalizer.GetLocalizedMessage(result.Error) ?? "Failed to change password.", result.IsSuccess ? NotificationSeverity.Success : NotificationSeverity.Error);
            if (result.IsSuccess)
            {
                _currentPassword = string.Empty;
                _newPassword = string.Empty;
                _confirmPassword = string.Empty;
            }
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task RemovePasswordAsync()
    {
        _isLoading = true;
        try
        {
            var result = await AuthService.RemovePasswordAsync();
            NotificationService.Add(result.IsSuccess ? "Password removed." : ErrorLocalizer.GetLocalizedMessage(result.Error) ?? "Failed to remove password.", result.IsSuccess ? NotificationSeverity.Success : NotificationSeverity.Error);
            if (result.IsSuccess)
            {
                _hasPassword = false;
            }
        }
        finally
        {
            _isLoading = false;
        }
    }
}
