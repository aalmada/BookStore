@page "/account/password"
@using Microsoft.AspNetCore.Authorization
@inject IConfiguration Configuration
@inject NavigationManager Navigation
@attribute [Authorize]

<PageTitle>Manage Account - BookStore</PageTitle>

<MudContainer MaxWidth="MaxWidth.Small" Class="mt-8">
    <MudPaper Elevation="4" Class="pa-8" Style="border-radius: 12px;">
        <MudText Typo="Typo.h5" Align="Align.Center">Redirecting to account settings...</MudText>
        <MudProgressCircular Class="mt-4" Color="Color.Primary" Indeterminate="true" />

        @if (!string.IsNullOrEmpty(_accountConsoleUrl))
        {
            <MudButton Class="mt-4" Variant="Variant.Outlined" Color="Color.Primary" Href="@_accountConsoleUrl" Target="_blank">
                Open Keycloak Account Console
            </MudButton>
        }
    </MudPaper>
</MudContainer>

@code {
    string? _accountConsoleUrl;

    protected override void OnInitialized()
    {
        var keycloakBaseUrl = Configuration[$"services:{BookStore.ServiceDefaults.ResourceNames.Keycloak}:https:0"]
            ?? Configuration[$"services:{BookStore.ServiceDefaults.ResourceNames.Keycloak}:http:0"];

        if (string.IsNullOrWhiteSpace(keycloakBaseUrl))
        {
            return;
        }

        _accountConsoleUrl = $"{keycloakBaseUrl.TrimEnd('/')}/realms/bookstore/account";
        Navigation.NavigateTo(_accountConsoleUrl, forceLoad: true);
    }
}
