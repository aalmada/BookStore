@page "/admin/books"
@layout AdminLayout
@using Microsoft.AspNetCore.Authorization
@using BookStore.Shared.Notifications
@using BookStore.Client
@attribute [Authorize(Roles = "Admin")]
@inject IBooksClient BooksClient
@inject BookStoreEventsService EventsService
@inject QueryInvalidationService InvalidationService
@inject ILogger<BookManagement> Logger
@implements IDisposable

<section class="admin-page">
    <header class="admin-page-header">
        <h1>Book Management</h1>
        <input class="input-field" @bind="search" @bind:event="oninput" placeholder="Search title..." />
    </header>

    @if (isLoading)
    {
        <p>Loading books...</p>
    }
    else if (books.Count == 0)
    {
        <p>No books found.</p>
    }
    else
    {
        <table class="admin-table">
            <thead>
                <tr>
                    <th>Title</th>
                    <th>ISBN</th>
                    <th>Language</th>
                    <th>Status</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var book in filteredBooks)
                {
                    <tr>
                        <td>@book.Title</td>
                        <td>@book.Isbn</td>
                        <td>@book.Language</td>
                        <td>@(book.IsDeleted ? "Deleted" : "Active")</td>
                    </tr>
                }
            </tbody>
        </table>
    }

    <div class="admin-page-footer">
        <button class="btn" @onclick="ReloadAsync">Refresh</button>
    </div>
</section>

@code {
    private List<AdminBookDto> books = [];
    private bool isLoading = true;
    private string search = string.Empty;

    private IEnumerable<AdminBookDto> filteredBooks => string.IsNullOrWhiteSpace(search)
        ? books
        : books.Where(b => b.Title.Contains(search, StringComparison.OrdinalIgnoreCase));

    protected override async Task OnInitializedAsync()
    {
        EventsService.StartListening();
        EventsService.OnNotificationReceived += HandleNotification;
        await ReloadAsync();
    }

    private async Task ReloadAsync()
    {
        isLoading = true;
        StateHasChanged();

        books = (await BooksClient.GetAllBooksAdminAsync(cancellationToken: CancellationToken.None)).ToList();
        isLoading = false;
        StateHasChanged();
    }

    private async void HandleNotification(IDomainEventNotification notification)
    {
        try
        {
            if (notification is PingNotification)
            {
                return;
            }

            if (InvalidationService.ShouldInvalidate(notification, ["Books"]))
            {
                await InvokeAsync(ReloadAsync);
            }
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Failed to process BookManagement notification");
        }
    }

    public void Dispose()
    {
        EventsService.OnNotificationReceived -= HandleNotification;
    }
}
