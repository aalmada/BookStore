@using BookStore.Client
@inject IPublishersClient PublishersClient

<dialog id="updatePublisherDialog">
    <header>
        <h2>Edit Publisher: @Publisher.Name</h2>
    </header>
    <form @onsubmit="HandleSubmit">
        <div>
            <label for="name">Name</label>
            <input id="name" type="text" @bind="_model.Name" required />
        </div>
        <footer>
            <button type="button" onclick="CloseDialog">Cancel</button>
            <button type="submit" disabled="@(!CanUpdate())">Update</button>
        </footer>
    </form>
</dialog>

@code {
    [Parameter] public PublisherDto Publisher { get; set; } = null!;

    private UpdatePublisherRequest _model = new();

    protected override void OnInitialized()
    {
        _model = new UpdatePublisherRequest { Name = Publisher.Name };
    }

    private bool CanUpdate()
    {
        return !string.IsNullOrWhiteSpace(_model.Name) && _model.Name != Publisher.Name;
    }

    private async Task HandleSubmit()
    {
        if (!CanUpdate()) return;

        try
        {
            await PublishersClient.UpdatePublisherAsync(Publisher.Id, _model);
            CloseDialog();
        }
        catch
        {
            // Handle error
        }
    }

    private void CloseDialog()
    {
        // Logic to close the dialog
    }
}
