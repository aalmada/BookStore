@* Refactored to remove MudBlazor components *@
@using BookStore.Client
@using BookStore.Shared.Models
@inject IAuthorsClient AuthorsClient

<div class="dialog">
    <div class="dialog-title">
        <h6>
            <span class="icon">✏️</span>
            Edit Author: @Author.Name
        </h6>
    </div>
    <div class="dialog-content">
        <form @onsubmit="Submit">
            <label for="author-name">Name</label>
            <input id="author-name" type="text" @bind="_model.Name" required placeholder="Enter author name" />

            <div class="card">
                <h6>Biographies (Multi-language)</h6>

                <div class="actions">
                    <select @bind="_selectedLanguage">
                        <option value="en">English</option>
                        <option value="es">Spanish</option>
                        <!-- Add more languages as needed -->
                    </select>
                    <button type="button" @onclick="AddOrUpdateBiography" disabled="@(!CanAddOrUpdateBiography())">
                        @(_translations.ContainsKey(_selectedLanguage) ? "Update" : "Add")
                    </button>
                </div>

                <textarea @bind="_currentBiography" placeholder="Enter biography..."></textarea>

                <ul>
                    @foreach (var translation in _translations)
                    {
                        <li>
                            <span><b>@translation.Key:</b> @(translation.Value.Length > 50 ? translation.Value[..50] + "..." : translation.Value)</span>
                            <button type="button" @onclick="() => RemoveBiography(translation.Key)" disabled="@(translation.Key == "en")">❌</button>
                        </li>
                    }
                </ul>
                @if (!_translations.ContainsKey("en"))
                {
                    <div class="alert">English biography is required!</div>
                }
            </div>
        </form>
    </div>
    <div class="dialog-actions">
        <button type="button" @onclick="Cancel">Cancel</button>
        <button type="submit" disabled="@(!CanUpdate())">Update</button>
    </div>
</div>

@code {
    [Parameter] public AdminAuthorDto Author { get; set; } = null!;

    private UpdateAuthorRequest _model = new();
    private string _selectedLanguage = "en";
    private string _currentBiography = string.Empty;
    private Dictionary<string, string> _translations = new();

    protected override void OnInitialized()
    {
        _model = new UpdateAuthorRequest { Name = Author.Name, Translations = new Dictionary<string, AuthorTranslationDto>() };

        if (Author.Translations != null)
        {
            foreach (var translation in Author.Translations)
            {
                _translations[translation.Key] = translation.Value.Biography;
            }

            if (_translations.TryGetValue("en", out var enBio))
            {
                _currentBiography = enBio;
            }
        }
        else if (!string.IsNullOrEmpty(Author.Biography))
        {
            _translations["en"] = Author.Biography;
            _currentBiography = Author.Biography;
        }
    }

    private void OnLanguageChanged(ChangeEventArgs e)
    {
        _selectedLanguage = e.Value?.ToString() ?? "en";
        _currentBiography = _translations.TryGetValue(_selectedLanguage, out var biography) ? biography : "";
    }

    private void AddOrUpdateBiography()
    {
        if (!string.IsNullOrWhiteSpace(_currentBiography))
        {
            _translations[_selectedLanguage] = _currentBiography;
        }
    }

    private void RemoveBiography(string language)
    {
        _translations.Remove(language);
    }

    private void Cancel()
    {
        // Logic to cancel the dialog
    }

    private void Submit()
    {
        // Logic to submit the form
    }

    private bool CanAddOrUpdateBiography() => !string.IsNullOrWhiteSpace(_currentBiography);
    private bool CanUpdate() => !string.IsNullOrWhiteSpace(_model.Name);
}
