@page "/admin/authors"
@layout AdminLayout
@using Microsoft.AspNetCore.Authorization
@using BookStore.Shared.Notifications
@attribute [Authorize(Roles = "Admin")]
@inject IAuthorsClient AuthorsClient
@inject BookStoreEventsService EventsService
@inject QueryInvalidationService InvalidationService
@inject INotificationService NotificationService
@inject ILogger<AuthorManagement> Logger
@implements IDisposable

<PageTitle>Author Management</PageTitle>

<section class="container mt-8">
    <header class="list-row mb-4">
        <h1>Author Management</h1>
        <button class="btn btn-primary" @onclick="OpenCreate">Add Author</button>
    </header>

    <AdminDataTable TItem="AdminAuthorDto" Items="@Filtered" IsLoading="@_isLoading" SearchPlaceholder="Search authors" OnSearch="OnSearchChanged" OnRefresh="LoadAsync">
        <RowContent Context="row">
            <tr>
                <td>@row.Name</td>
                <td class="list-row">
                    <button class="btn btn-ghost" @onclick="(() => OpenEdit(row))">Edit</button>
                    <button class="btn btn-ghost" @onclick="(() => DeleteAsync(row))">Delete</button>
                </td>
            </tr>
        </RowContent>
    </AdminDataTable>

    <EntityFormModal Title="@(_isEdit ? "Edit Author" : "Create Author")" IsVisible="@_showModal" OnClose="CloseAsync">
        <AdminAuthorForm Model="@_model" OnSubmit="SubmitAsync" />
    </EntityFormModal>
</section>

@code {
    private List<AdminAuthorDto> _rows = [];
    private bool _isLoading = true;
    private string _search = string.Empty;
    private bool _showModal;
    private bool _isEdit;
    private Guid _id;
    private string? _etag;
    private CreateAuthorRequest _model = new() { Translations = new Dictionary<string, AuthorTranslationDto>() };

    private IEnumerable<AdminAuthorDto> Filtered => string.IsNullOrWhiteSpace(_search) ? _rows : _rows.Where(x => x.Name.Contains(_search, StringComparison.OrdinalIgnoreCase));

    protected override async Task OnInitializedAsync()
    {
        EventsService.StartListening();
        EventsService.OnNotificationReceived += HandleNotification;
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _isLoading = true;
        _rows = (await AuthorsClient.GetAllAuthorsAsync(new AuthorSearchRequest { Page = 1, PageSize = 250 })).Items.ToList();
        _isLoading = false;
    }

    private Task OnSearchChanged(string value) { _search = value; return Task.CompletedTask; }

    private void OpenCreate()
    {
        _isEdit = false;
        _id = Guid.Empty;
        _etag = null;
        _model = new CreateAuthorRequest { Translations = new Dictionary<string, AuthorTranslationDto>() };
        _showModal = true;
    }

    private void OpenEdit(AdminAuthorDto row)
    {
        _isEdit = true;
        _id = row.Id;
        _etag = row.ETag;
        _model = new CreateAuthorRequest { Id = row.Id, Name = row.Name, Translations = row.Translations?.ToDictionary(x => x.Key, x => x.Value) ?? new Dictionary<string, AuthorTranslationDto>() };
        _showModal = true;
    }

    private async Task SubmitAsync(CreateAuthorRequest model)
    {
        if (_isEdit)
        {
            await AuthorsClient.UpdateAuthorAsync(_id, new UpdateAuthorRequest { Name = model.Name, Translations = model.Translations }, _etag);
            NotificationService.Add("Author updated", NotificationSeverity.Success);
        }
        else
        {
            await AuthorsClient.CreateAuthorAsync(model);
            NotificationService.Add("Author created", NotificationSeverity.Success);
        }

        _showModal = false;
        await LoadAsync();
    }

    private async Task DeleteAsync(AdminAuthorDto row)
    {
        await AuthorsClient.SoftDeleteAuthorAsync(row.Id, row.ETag);
        NotificationService.Add("Author deleted", NotificationSeverity.Success);
        await LoadAsync();
    }

    private Task CloseAsync() { _showModal = false; return Task.CompletedTask; }

    private async void HandleNotification(IDomainEventNotification n)
    {
        try
        {
            if (n is not PingNotification && InvalidationService.ShouldInvalidate(n, ["Authors"])) await InvokeAsync(LoadAsync);
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Author notifications failed");
        }
    }

    public void Dispose() => EventsService.OnNotificationReceived -= HandleNotification;
}
