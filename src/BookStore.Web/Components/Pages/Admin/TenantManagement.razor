@page "/admin/tenants"
@layout AdminLayout
@using BookStore.Client
@using Microsoft.AspNetCore.Authorization
@using BookStore.Shared.Models
@using BookStore.Shared.Notifications
@attribute [Authorize(Policy = "SystemAdmin")]
@inject ITenantsClient TenantClient
@inject TenantService TenantService
@inject BookStoreEventsService EventsService
@inject QueryInvalidationService InvalidationService
@inject ILogger<TenantManagement> Logger
@implements IDisposable

<PageTitle>Tenant Management</PageTitle>

<section class="container mt-8">
    <header class="list-row mb-4"><h1>Tenant Management</h1><button class="btn btn-primary" @onclick="OpenCreate">Create Tenant</button></header>
    <AdminDataTable TItem="TenantInfoDto" Items="@Filtered" IsLoading="@_isLoading" SearchPlaceholder="Search tenants" OnSearch="OnSearchChanged" OnRefresh="LoadAsync">
        <RowContent Context="row">
            <tr>
                <td>@row.Id</td>
                <td>@row.Name</td>
                <td>@(row.IsEnabled ? "Enabled" : "Disabled")</td>
                <td><button class="btn btn-ghost" @onclick="(() => OpenEdit(row))">Edit</button></td>
            </tr>
        </RowContent>
    </AdminDataTable>
    <EntityFormModal Title="@(_isEdit ? "Edit Tenant" : "Create Tenant")" IsVisible="@_show" OnClose="CloseAsync">
        <AdminTenantForm Model="@_model" IsEdit="@_isEdit" OnSubmit="SubmitAsync" />
    </EntityFormModal>
</section>

@code {
    private List<TenantInfoDto> _rows = [];
    private bool _isLoading = true;
    private string _search = string.Empty;
    private bool _show;
    private bool _isEdit;
    private AdminTenantForm.TenantModel _model = new();

    private IEnumerable<TenantInfoDto> Filtered => string.IsNullOrWhiteSpace(_search) ? _rows : _rows.Where(x => x.Name.Contains(_search, StringComparison.OrdinalIgnoreCase) || x.Id.Contains(_search, StringComparison.OrdinalIgnoreCase));

    protected override async Task OnInitializedAsync()
    {
        EventsService.StartListening();
        EventsService.OnNotificationReceived += HandleNotification;
        await LoadAsync();
    }

    private async Task LoadAsync() { _isLoading = true; _rows = await TenantClient.GetAllTenantsAdminAsync(); _isLoading = false; }
    private Task OnSearchChanged(string value) { _search = value; return Task.CompletedTask; }
    private void OpenCreate() { _isEdit = false; _model = new AdminTenantForm.TenantModel { IsEnabled = true, ThemePrimaryColor = "#594AE2" }; _show = true; }
    private void OpenEdit(TenantInfoDto row) { _isEdit = true; _model = new AdminTenantForm.TenantModel { Id = row.Id, Name = row.Name, Tagline = row.Tagline, ThemePrimaryColor = row.ThemePrimaryColor, IsEnabled = row.IsEnabled, ETag = row.ETag }; _show = true; }
    private Task CloseAsync() { _show = false; return Task.CompletedTask; }
    private async Task SubmitAsync(AdminTenantForm.TenantModel model)
    {
        if (_isEdit) await TenantClient.UpdateTenantAsync(model.Id, new UpdateTenantCommand(model.Name, model.Tagline, model.ThemePrimaryColor, model.IsEnabled), model.ETag);
        else await TenantClient.CreateTenantAsync(new CreateTenantCommand(model.Id, model.Name, model.Tagline, model.ThemePrimaryColor, model.IsEnabled, model.AdminEmail, model.AdminPassword));
        _show = false;
        await LoadAsync();
        await TenantService.RefreshAvailableTenantsAsync();
    }

    private async void HandleNotification(IDomainEventNotification n)
    {
        try
        {
            if (n is not PingNotification && InvalidationService.ShouldInvalidate(n, ["Tenants"])) await InvokeAsync(async () => { await LoadAsync(); await TenantService.RefreshAvailableTenantsAsync(); });
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Tenant notifications failed");
        }
    }

    public void Dispose() => EventsService.OnNotificationReceived -= HandleNotification;
}
