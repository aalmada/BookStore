@page "/admin/publishers"
@layout AdminLayout
@using Microsoft.AspNetCore.Authorization
@using BookStore.Shared.Notifications
@attribute [Authorize(Roles = "Admin")]
@inject IPublishersClient PublishersClient
@inject BookStoreEventsService EventsService
@inject QueryInvalidationService InvalidationService
@inject INotificationService NotificationService
@inject ILogger<PublisherManagement> Logger
@implements IDisposable

<PageTitle>Publisher Management</PageTitle>

<section class="container mt-8">
    <header class="list-row mb-4">
        <h1>Publisher Management</h1>
        <button class="btn btn-primary" @onclick="OpenCreate">Add Publisher</button>
    </header>

    <AdminDataTable TItem="PublisherDto" Items="@Filtered" IsLoading="@_isLoading" SearchPlaceholder="Search publishers" OnSearch="OnSearchChanged" OnRefresh="LoadAsync">
        <RowContent Context="row">
            <tr>
                <td>@row.Name</td>
                <td class="list-row">
                    <button class="btn btn-ghost" @onclick="(() => OpenEdit(row))">Edit</button>
                    <button class="btn btn-ghost" @onclick="(() => DeleteAsync(row))">Delete</button>
                </td>
            </tr>
        </RowContent>
    </AdminDataTable>

    <EntityFormModal Title="@(_isEdit ? "Edit Publisher" : "Create Publisher")" IsVisible="@_showModal" OnClose="CloseAsync">
        <AdminPublisherForm Model="@_model" OnSubmit="SubmitAsync" />
    </EntityFormModal>
</section>

@code {
    private List<PublisherDto> _rows = [];
    private bool _isLoading = true;
    private string _search = string.Empty;
    private bool _showModal;
    private bool _isEdit;
    private Guid _id;
    private string? _etag;
    private CreatePublisherRequest _model = new();

    private IEnumerable<PublisherDto> Filtered => string.IsNullOrWhiteSpace(_search) ? _rows : _rows.Where(x => x.Name.Contains(_search, StringComparison.OrdinalIgnoreCase));

    protected override async Task OnInitializedAsync()
    {
        EventsService.StartListening();
        EventsService.OnNotificationReceived += HandleNotification;
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _isLoading = true;
        _rows = (await PublishersClient.GetAllPublishersAsync(new PublisherSearchRequest { Page = 1, PageSize = 250 })).Items.ToList();
        _isLoading = false;
    }

    private Task OnSearchChanged(string value) { _search = value; return Task.CompletedTask; }
    private void OpenCreate() { _isEdit = false; _id = Guid.Empty; _etag = null; _model = new CreatePublisherRequest(); _showModal = true; }
    private void OpenEdit(PublisherDto row) { _isEdit = true; _id = row.Id; _etag = row.ETag; _model = new CreatePublisherRequest { Id = row.Id, Name = row.Name }; _showModal = true; }

    private async Task SubmitAsync(CreatePublisherRequest model)
    {
        if (_isEdit) await PublishersClient.UpdatePublisherAsync(_id, new UpdatePublisherRequest { Name = model.Name }, _etag);
        else await PublishersClient.CreatePublisherAsync(model);
        _showModal = false;
        await LoadAsync();
    }

    private async Task DeleteAsync(PublisherDto row) { await PublishersClient.SoftDeletePublisherAsync(row.Id, row.ETag); await LoadAsync(); }
    private Task CloseAsync() { _showModal = false; return Task.CompletedTask; }

    private async void HandleNotification(IDomainEventNotification n)
    {
        try
        {
            if (n is not PingNotification && InvalidationService.ShouldInvalidate(n, ["Publishers"])) await InvokeAsync(LoadAsync);
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Publisher notifications failed");
        }
    }

    public void Dispose() => EventsService.OnNotificationReceived -= HandleNotification;
}
