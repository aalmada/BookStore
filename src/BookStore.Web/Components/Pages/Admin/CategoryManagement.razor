@page "/admin/categories"
@layout AdminLayout
@using Microsoft.AspNetCore.Authorization
@using BookStore.Shared.Notifications
@attribute [Authorize(Roles = "Admin")]
@inject ICategoriesClient CategoriesClient
@inject BookStoreEventsService EventsService
@inject QueryInvalidationService InvalidationService
@inject ILogger<CategoryManagement> Logger
@implements IDisposable

<PageTitle>Category Management</PageTitle>

<section class="container mt-8">
    <header class="list-row mb-4"><h1>Category Management</h1><button class="btn btn-primary" @onclick="OpenCreate">Add Category</button></header>
    <AdminDataTable TItem="AdminCategoryDto" Items="@Filtered" IsLoading="@_isLoading" SearchPlaceholder="Search categories" OnSearch="OnSearchChanged" OnRefresh="LoadAsync">
        <RowContent Context="row">
            <tr>
                <td>@row.Name</td>
                <td class="list-row"><button class="btn btn-ghost" @onclick="(() => OpenEdit(row))">Edit</button><button class="btn btn-ghost" @onclick="(() => DeleteAsync(row))">Delete</button></td>
            </tr>
        </RowContent>
    </AdminDataTable>
    <EntityFormModal Title="@(_isEdit ? "Edit Category" : "Create Category")" IsVisible="@_showModal" OnClose="CloseAsync">
        <AdminCategoryForm Model="@_model" OnSubmit="SubmitAsync" />
    </EntityFormModal>
</section>

@code {
    private List<AdminCategoryDto> _rows = [];
    private bool _isLoading = true;
    private string _search = string.Empty;
    private bool _showModal;
    private bool _isEdit;
    private Guid _id;
    private string? _etag;
    private CreateCategoryRequest _model = new() { Translations = new Dictionary<string, CategoryTranslationDto>() };

    private IEnumerable<AdminCategoryDto> Filtered => string.IsNullOrWhiteSpace(_search) ? _rows : _rows.Where(x => x.Name.Contains(_search, StringComparison.OrdinalIgnoreCase));

    protected override async Task OnInitializedAsync()
    {
        EventsService.StartListening();
        EventsService.OnNotificationReceived += HandleNotification;
        await LoadAsync();
    }

    private async Task LoadAsync() { _isLoading = true; _rows = (await CategoriesClient.GetAllCategoriesAsync(new CategorySearchRequest { Page = 1, PageSize = 250 })).Items.ToList(); _isLoading = false; }
    private Task OnSearchChanged(string value) { _search = value; return Task.CompletedTask; }
    private void OpenCreate() { _isEdit = false; _id = Guid.Empty; _etag = null; _model = new CreateCategoryRequest { Translations = new Dictionary<string, CategoryTranslationDto>() }; _showModal = true; }
    private void OpenEdit(AdminCategoryDto row) { _isEdit = true; _id = row.Id; _etag = row.ETag; _model = new CreateCategoryRequest { Id = row.Id, Translations = row.Translations.ToDictionary(x => x.Key, x => x.Value) }; _showModal = true; }
    private async Task SubmitAsync(CreateCategoryRequest model) { if (_isEdit) await CategoriesClient.UpdateCategoryAsync(_id, new UpdateCategoryRequest { Translations = model.Translations }, _etag); else await CategoriesClient.CreateCategoryAsync(model); _showModal = false; await LoadAsync(); }
    private async Task DeleteAsync(AdminCategoryDto row) { await CategoriesClient.SoftDeleteCategoryAsync(row.Id, row.ETag); await LoadAsync(); }
    private Task CloseAsync() { _showModal = false; return Task.CompletedTask; }

    private async void HandleNotification(IDomainEventNotification n)
    {
        try
        {
            if (n is not PingNotification && InvalidationService.ShouldInvalidate(n, ["Categories"])) await InvokeAsync(LoadAsync);
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Category notifications failed");
        }
    }

    public void Dispose() => EventsService.OnNotificationReceived -= HandleNotification;
}
