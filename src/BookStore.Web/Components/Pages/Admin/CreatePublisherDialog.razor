@using BookStore.Client
@inject IPublishersClient PublishersClient

<dialog id="createPublisherDialog">
    <header>
        <h2>Add New Publisher</h2>
    </header>
    <form @onsubmit="HandleSubmit">
        <div>
            <label for="name">Name</label>
            <input id="name" type="text" @bind="_model.Name" required />
        </div>
        <footer>
            <button type="button" onclick="CloseDialog">Cancel</button>
            <button type="submit" disabled="@(!CanCreate())">Create</button>
        </footer>
    </form>
</dialog>

@code {
    private CreatePublisherRequest _model = new();

    private bool CanCreate()
    {
        return !string.IsNullOrWhiteSpace(_model.Name);
    }

    private async Task HandleSubmit()
    {
        if (!CanCreate()) return;

        try
        {
            await PublishersClient.CreatePublisherAsync(_model);
            CloseDialog();
        }
        catch
        {
            // Handle error
        }
    }

    private void CloseDialog()
    {
        // Logic to close the dialog
    }
}
