@* Refactored to remove MudBlazor components *@
@using BookStore.Client
@using BookStore.Shared.Models
@inject ICategoriesClient CategoriesClient

<div class="dialog">
    <div class="dialog-title">
        <h6>
            <span class="icon">✏️</span>
            Edit Category: @Category.Name
        </h6>
    </div>
    <div class="dialog-content">
        <form @onsubmit="Submit">
            <div class="card">
                <h6>Translations (Multi-language)</h6>

                <div class="actions">
                    <select @bind="_selectedLanguage">
                        <option value="en">English</option>
                        <option value="es">Spanish</option>
                        <!-- Add more languages as needed -->
                    </select>
                    <button type="button" @onclick="AddOrUpdateTranslation" disabled="@(!CanAddOrUpdateTranslation())">
                        @(_translations.ContainsKey(_selectedLanguage) ? "Update" : "Add")
                    </button>
                </div>

                <label for="translation-name">@($"Name ({_selectedLanguage})")</label>
                <input id="translation-name" type="text" @bind="_currentName" required placeholder="Enter name for the language" />

                <ul>
                    @foreach (var translation in _translations.OrderBy(t => t.Key))
                    {
                        <li>
                            <span><b>@translation.Key:</b> @translation.Value</span>
                            <button type="button" @onclick="() => RemoveTranslation(translation.Key)" disabled="@(translation.Key == "en")">❌</button>
                        </li>
                    }
                </ul>
                @if (!_translations.ContainsKey("en"))
                {
                    <div class="alert">English translation is required!</div>
                }
            </div>
        </form>
    </div>
    <div class="dialog-actions">
        <button type="button" @onclick="Cancel">Cancel</button>
        <button type="submit" disabled="@(!CanUpdate())">Update</button>
    </div>
</div>

@code {
    [Parameter] public AdminCategoryDto Category { get; set; } = null!;

    private string _selectedLanguage = "en";
    private string _currentName = string.Empty;
    private Dictionary<string, string> _translations = new();

    protected override void OnInitialized()
    {
        if (Category.Translations != null)
        {
            foreach (var translation in Category.Translations)
            {
                _translations[translation.Key] = translation.Value.Name;
            }

            if (_translations.TryGetValue("en", out var enName))
            {
                _currentName = enName;
            }
        }
        else
        {
            _translations["en"] = Category.Name;
            _currentName = Category.Name;
        }
    }

    private void OnLanguageChanged(ChangeEventArgs e)
    {
        _selectedLanguage = e.Value?.ToString() ?? "en";
        _currentName = _translations.TryGetValue(_selectedLanguage, out var name) ? name : "";
    }

    private void AddOrUpdateTranslation()
    {
        if (!string.IsNullOrWhiteSpace(_currentName))
        {
            _translations[_selectedLanguage] = _currentName;
        }
    }

    private void RemoveTranslation(string language)
    {
        _translations.Remove(language);
    }

    private void Cancel()
    {
        // Logic to cancel the dialog
    }

    private void Submit()
    {
        // Logic to submit the form
    }

    private bool CanAddOrUpdateTranslation() => !string.IsNullOrWhiteSpace(_currentName);
    private bool CanUpdate() => !string.IsNullOrWhiteSpace(_currentName);
}
