@page "/admin/users"
@layout AdminLayout
@using Microsoft.AspNetCore.Authorization
@using BookStore.Shared.Notifications
@attribute [Authorize(Roles = "Admin")]
@inject IUsersClient UserClient
@inject AuthenticationStateProvider AuthStateProvider
@inject BookStoreEventsService EventsService
@inject QueryInvalidationService InvalidationService
@inject INotificationService NotificationService
@inject ILogger<UserManagement> Logger
@implements IDisposable

<PageTitle>User Management</PageTitle>

<section class="container mt-8">
    <h1>User Management</h1>
    <AdminDataTable TItem="UserAdminDto" Items="@Filtered" IsLoading="@_isLoading" SearchPlaceholder="Search users" OnSearch="OnSearchChanged" OnRefresh="LoadAsync">
        <RowContent Context="row">
            <tr>
                <td>@row.Email</td>
                <td>@(row.EmailConfirmed ? "Verified" : "Pending")</td>
                <td>@string.Join(", ", row.Roles)</td>
                <td>
                    @if (!string.Equals(row.Email, _currentUserEmail, StringComparison.OrdinalIgnoreCase))
                    {
                        @if (row.Roles.Contains("Admin"))
                        {
                            <button class="btn btn-ghost" @onclick="(() => Demote(row))">Demote</button>
                        }
                        else
                        {
                            <button class="btn btn-primary" @onclick="(() => Promote(row))">Promote</button>
                        }
                    }
                </td>
            </tr>
        </RowContent>
    </AdminDataTable>
</section>

@code {
    private List<UserAdminDto> _rows = [];
    private bool _isLoading = true;
    private string _search = string.Empty;
    private string? _currentUserEmail;
    private IEnumerable<UserAdminDto> Filtered => string.IsNullOrWhiteSpace(_search) ? _rows : _rows.Where(x => x.Email.Contains(_search, StringComparison.OrdinalIgnoreCase));

    protected override async Task OnInitializedAsync()
    {
        var auth = await AuthStateProvider.GetAuthenticationStateAsync();
        _currentUserEmail = auth.User.Identity?.Name;
        EventsService.StartListening();
        EventsService.OnNotificationReceived += HandleNotification;
        await LoadAsync();
    }

    private async Task LoadAsync() { _isLoading = true; _rows = (await UserClient.GetUsersAsync(page: 1, pageSize: 250)).Items.ToList(); _isLoading = false; }
    private Task OnSearchChanged(string value) { _search = value; return Task.CompletedTask; }
    private async Task Promote(UserAdminDto row) { await UserClient.PromoteToAdminAsync(row.Id); NotificationService.Add("User promoted", NotificationSeverity.Success); await LoadAsync(); }
    private async Task Demote(UserAdminDto row) { await UserClient.DemoteFromAdminAsync(row.Id); NotificationService.Add("User demoted", NotificationSeverity.Success); await LoadAsync(); }

    private async void HandleNotification(IDomainEventNotification n)
    {
        try
        {
            if (n is not PingNotification && InvalidationService.ShouldInvalidate(n, ["Users"])) await InvokeAsync(LoadAsync);
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "User notifications failed");
        }
    }

    public void Dispose() => EventsService.OnNotificationReceived -= HandleNotification;
}
