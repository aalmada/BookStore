@page "/cart"
@using BookStore.Client
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize]
@inject IShoppingCartClient CartClient
@inject INotificationService NotificationService
@inject NavigationManager Navigation
@implements IDisposable
@rendermode InteractiveServer
@inject CurrencyService CurrencyService
@inject BookStoreEventsService EventsService
@inject QueryInvalidationService InvalidationService
@inject ILogger<ShoppingCart> Logger

<PageTitle>Shopping Cart - BookStore</PageTitle>

<section class="container mt-8">
    <header class="list-row mb-6" style="align-items:end;">
        <div>
            <h1>Shopping Cart (@(cart?.TotalItems ?? 0) items)</h1>
        </div>
        <a class="btn btn-ghost" href="/">Continue Shopping</a>
    </header>

    @if (isLoading)
    {
        <LoadingSpinner IsVisible="true" Message="Loading your cart" />
    }
    else if (cart is not null && cart.Items.Count > 0)
    {
        <div class="cart-grid" style="display:grid;grid-template-columns:2fr 1fr;gap:var(--space-6);">
            <section class="card" style="padding:var(--space-6);">
                @foreach (var item in cart.Items)
                {
                    <CartItem Item="item" OnQuantityChanged="OnQuantityChangedAsync" OnRemoved="RemoveItemAsync" />
                }
            </section>

            <aside class="card" style="padding:var(--space-6);position:sticky;top:var(--space-6);height:fit-content;">
                <CartSummary Cart="cart" OnClearCart="ClearCartAsync" OnContinueShopping="ContinueShoppingAsync" />
                <button class="btn btn-primary" style="width:100%;margin-top:var(--space-4);" disabled="@(cart.TotalItems == 0)">Checkout (Coming Soon)</button>
            </aside>
        </div>
    }
    else
    {
        <EmptyState Title="Your cart is empty"
                    Message="Add books to start building your next reading order."
                    ActionLabel="Browse catalog"
                    OnAction="ContinueShoppingAsync" />
    }
</section>

@code {
    private ReactiveQuery<ShoppingCartResponse?>? cartQuery;
    private ShoppingCartResponse? cart => cartQuery?.Data;
    private bool isLoading => cartQuery?.IsLoading ?? true;
    private readonly CancellationTokenSource _cts = new();
    private bool _disposed;

    protected override async Task OnInitializedAsync()
    {
        // Start SSE listening
        EventsService.StartListening();

        await InitializeQueryAsync(_cts.Token);

        // Subscribe to currency changes
        CurrencyService.OnCurrencyChanged += StateHasChanged;
    }

    private async Task InitializeQueryAsync(CancellationToken cancellationToken = default)
    {
        // Dispose previous if exists
        cartQuery?.Dispose();

        cartQuery = new ReactiveQuery<ShoppingCartResponse?>(
            queryFn: async ct =>
            {
                try
                {
                    return await CartClient.GetShoppingCartAsync(ct);
                }
                catch (Refit.ApiException apiEx) when (apiEx.StatusCode == System.Net.HttpStatusCode.Unauthorized)
                {
                    throw new Exception("Please log in to view your cart.");
                }
            },
            eventsService: EventsService,
            invalidationService: InvalidationService,
            queryKeys: new[] { "User" },
            onStateChanged: () => InvokeAsync(StateHasChanged),
            logger: Logger
        );

        await cartQuery.LoadAsync(cancellationToken: cancellationToken);
    }

    private Task OnQuantityChangedAsync((Guid, int) change) => UpdateQuantityAsync(change.Item1, change.Item2);

    private async Task UpdateQuantityAsync(Guid bookId, int newQuantity)
    {
        if (newQuantity <= 0 || cart == null) return;

        // Find current item
        var currentItem = cart.Items.FirstOrDefault(i => i.BookId == bookId);
        if (currentItem == null) return;

        var previousQuantity = currentItem.Quantity;

        // 1. Optimistic update
        cartQuery?.MutateData(current => current == null
            ? null
            : new ShoppingCartResponse(
                current.Items.Select(i => i.BookId == bookId
                    ? i with { Quantity = newQuantity }
                    : i).ToList(),
                current.TotalItems - previousQuantity + newQuantity
            ));

        // 2. API Call
        try
        {
            await CartClient.UpdateCartItemAsync(bookId, new UpdateCartItemClientRequest(newQuantity), _cts.Token);
            NotificationService.Add("Quantity updated", NotificationSeverity.Success);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to update quantity for book {BookId}", bookId);
            // 3. Rollback
            cartQuery?.MutateData(current => current == null
                ? null
                : new ShoppingCartResponse(
                    current.Items.Select(i => i.BookId == bookId
                        ? i with { Quantity = previousQuantity }
                        : i).ToList(),
                    current.TotalItems - newQuantity + previousQuantity
                ));
            NotificationService.Add($"Failed to update: {ex.Message}", NotificationSeverity.Error);
        }
    }

    private async Task RemoveItemAsync(Guid bookId)
    {
        if (cart == null) return;

        var itemToRemove = cart.Items.FirstOrDefault(i => i.BookId == bookId);
        if (itemToRemove == null) return;

        // 1. Optimistic update
        cartQuery?.MutateData(current => current == null
            ? null
            : new ShoppingCartResponse(
                current.Items.Where(i => i.BookId != bookId).ToList(),
                current.TotalItems - itemToRemove.Quantity
            ));

        // 2. API Call
        try
        {
            await CartClient.RemoveFromCartAsync(bookId, _cts.Token);
            NotificationService.Add("Item removed from cart", NotificationSeverity.Success);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to remove item {BookId}", bookId);
            // 3. Rollback
            cartQuery?.MutateData(current => current == null
                ? null
                : new ShoppingCartResponse(
                    current.Items.Append(itemToRemove).ToList(),
                    current.TotalItems + itemToRemove.Quantity
                ));
            NotificationService.Add($"Failed to remove: {ex.Message}", NotificationSeverity.Error);
        }
    }

    private async Task ClearCartAsync()
    {
        if (cart == null || cart.Items.Count == 0) return;

        var previousCart = cart;

        // 1. Optimistic update
        cartQuery?.MutateData(_ => new ShoppingCartResponse([], 0));

        // 2. API Call
        try
        {
            await CartClient.ClearCartAsync(_cts.Token);
            NotificationService.Add("Cart cleared", NotificationSeverity.Success);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to clear cart");
            // 3. Rollback
            cartQuery?.MutateData(_ => previousCart);
            NotificationService.Add($"Failed to clear cart: {ex.Message}", NotificationSeverity.Error);
        }
    }

    private Task ContinueShoppingAsync()
    {
        Navigation.NavigateTo("/");
        return Task.CompletedTask;
    }

    public void Dispose()
    {
        if (_disposed) return;
        _disposed = true;

        _cts.Cancel();
        _cts.Dispose();
        cartQuery?.Dispose();
        CurrencyService.OnCurrencyChanged -= StateHasChanged;
    }

}
