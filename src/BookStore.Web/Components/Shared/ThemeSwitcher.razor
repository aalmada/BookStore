@inject ThemeService ThemeInfo
@implements IDisposable

<div class="menu-shell">
    <button class="btn btn-ghost" @onclick="ToggleMenu" aria-haspopup="menu" aria-expanded="@_menuOpen">Theme</button>
    @if (_menuOpen)
    {
        <div class="menu-panel" role="menu">
            <button class="menu-item" role="menuitem" @onclick="() => SetTheme(ThemeMode.Light)">Light</button>
            <button class="menu-item" role="menuitem" @onclick="() => SetTheme(ThemeMode.Dark)">Dark</button>
            <button class="menu-item" role="menuitem" @onclick="() => SetTheme(ThemeMode.System)">System</button>
        </div>
    }
</div>

@code {
    private bool _menuOpen;

    private void ToggleMenu() => _menuOpen = !_menuOpen;

    private async Task SetTheme(ThemeMode mode)
    {
        _menuOpen = false;
        await ThemeInfo.SetThemeModeAsync(mode);
    }

    protected override void OnInitialized()
    {
        ThemeInfo.OnChange += StateHasChanged;
    }

    public void Dispose()
    {
        ThemeInfo.OnChange -= StateHasChanged;
    }

}
