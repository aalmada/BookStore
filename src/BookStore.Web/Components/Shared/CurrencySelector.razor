@inject CurrencyService CurrencyService
@implements IDisposable

<div class="menu-shell">
    <button class="btn btn-ghost" @onclick="ToggleMenu" aria-haspopup="menu" aria-expanded="@_menuOpen">@CurrencyService.CurrentCurrency</button>
    @if (_menuOpen)
    {
        <div class="menu-panel" role="menu">
            @foreach (var currency in _currencies)
            {
                <button class="menu-item" role="menuitem" @onclick="() => SetCurrencyAsync(currency)">@GetCurrencyFlag(currency) @currency</button>
            }
        </div>
    }
</div>

@code {
    private readonly string[] _currencies = { "USD", "EUR", "GBP" };
    private bool _menuOpen;

    private void ToggleMenu() => _menuOpen = !_menuOpen;

    protected override async Task OnInitializedAsync()
    {
        CurrencyService.OnCurrencyChanged += StateHasChanged;
        await CurrencyService.InitializeAsync();
    }

    private async Task SetCurrencyAsync(string currency)
    {
        _menuOpen = false;
        await CurrencyService.SetCurrencyAsync(currency);
    }

    private string GetCurrencyFlag(string currency) => currency switch
    {
        "USD" => "🇺🇸",
        "EUR" => "🇪🇺",
        "GBP" => "🇬🇧",
        _ => "🏳️"
    };

    public void Dispose()
    {
        CurrencyService.OnCurrencyChanged -= StateHasChanged;
    }

}
