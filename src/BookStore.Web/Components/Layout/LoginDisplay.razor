@using Microsoft.AspNetCore.Components.Authorization
@inject IConfiguration Configuration
@inject NavigationManager Navigation

<AuthorizeView>
    <Authorized>
        <MudTooltip Text="Account Settings" Arrow="true" Placement="Placement.Bottom" Disabled="@_isUserMenuOpen">
            <MudMenu @bind-Open="@_isUserMenuOpen" Icon="@Icons.Material.Filled.AccountCircle" Color="Color.Inherit" AnchorOrigin="Origin.BottomRight">
                <MudMenuItem>
                    <MudText Typo="Typo.body2">@context.User.Identity?.Name</MudText>
                </MudMenuItem>
                <MudDivider/>
                <MudMenuItem Href="@_accountConsoleUrl" Target="_blank">
                    <MudIcon Icon="@Icons.Material.Filled.ManageAccounts" Class="mr-2"/>
                    Manage Account
                </MudMenuItem>
                <MudMenuItem OnClick="HandleLogout">
                    <MudIcon Icon="@Icons.Material.Filled.Logout" Class="mr-2"/>
                    Logout
                </MudMenuItem>
            </MudMenu>
        </MudTooltip>
    </Authorized>
    <NotAuthorized>
        <MudTooltip Text="Login" Arrow="true" Placement="Placement.Bottom">
            <MudButton Href="/login/oidc" Variant="Variant.Text" Color="Color.Inherit" StartIcon="@Icons.Material.Filled.Login">
                Login
            </MudButton>
        </MudTooltip>
        <MudTooltip Text="Create Account" Arrow="true" Placement="Placement.Bottom">
            <MudButton Href="/register" Variant="Variant.Outlined" Color="Color.Inherit" StartIcon="@Icons.Material.Filled.PersonAdd">
                Register
            </MudButton>
        </MudTooltip>
    </NotAuthorized>
</AuthorizeView>

@code {
    bool _isUserMenuOpen;
    string _accountConsoleUrl = "/account/password";

    protected override void OnInitialized()
    {
        var keycloakBaseUrl = Configuration[$"services:{BookStore.ServiceDefaults.ResourceNames.Keycloak}:https:0"]
            ?? Configuration[$"services:{BookStore.ServiceDefaults.ResourceNames.Keycloak}:http:0"];

        if (!string.IsNullOrWhiteSpace(keycloakBaseUrl))
        {
            _accountConsoleUrl = $"{keycloakBaseUrl.TrimEnd('/')}/realms/bookstore/account";
        }
    }

    void HandleLogout()
    {
        Navigation.NavigateTo("/logout", forceLoad: true);
    }

}
