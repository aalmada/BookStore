@using Microsoft.AspNetCore.Components.Authorization
@using BookStore.Web.Services
@using Microsoft.JSInterop
@inject AuthenticationService AuthService
@inject JwtAuthenticationStateProvider AuthStateProvider
@inject NavigationManager Navigation
@inject IJSRuntime JS

<AuthorizeView>
    <Authorized>
        <div class="menu-shell">
            <button class="btn btn-ghost" @onclick="HandleMenuToggle" aria-haspopup="menu" aria-expanded="@_isUserMenuOpen">@context.User.Identity?.Name</button>
            @if (_isUserMenuOpen)
            {
                <div class="menu-panel" role="menu">
                    <a class="menu-item" role="menuitem" href="/account/password">Manage Password</a>
                    <a class="menu-item" role="menuitem" href="/account/passkeys">Manage Passkeys</a>
                    <button class="menu-item" role="menuitem" @onclick="HandleLogout">Logout</button>
                </div>
            }
        </div>
    </Authorized>
    <NotAuthorized>
        <div class="auth-links">
            <a href="/login" class="btn btn-ghost">Login</a>
            <a href="/register" class="btn btn-primary">Register</a>
        </div>
    </NotAuthorized>
</AuthorizeView>

@code {
    bool _isUserMenuOpen;

    private void HandleMenuToggle(EventArgs _)
    {
        _isUserMenuOpen = !_isUserMenuOpen;
    }

    async Task HandleLogout()
    {
        await AuthService.LogoutAsync();

        // Notify the authentication state provider that the user has logged out
        // This triggers UI updates for AuthorizeView and other auth-dependent components
        await AuthStateProvider.NotifyUserLogout();

        // Notify other tabs via BroadcastChannel
        try
        {
            await JS.InvokeVoidAsync("authBroadcast.notifyLogout");
        }
        catch
        {
            // BroadcastChannel might not be available, continue anyway
        }

        // Navigate without forceLoad - state is already updated
        Navigation.NavigateTo("/");
    }

}
