@inherits LayoutComponentBase

<div class="layout-root">
    <BookStore.Web.Components.Shared.LogEnricher/>
    <BookStore.Web.Components.Shared.NotificationToasts/>

    <header class="layout-header">
        <div class="layout-header-brand">
            <button class="btn btn-ghost layout-drawer-toggle" @onclick="ToggleDrawer" aria-label="Toggle Navigation">Menu</button>
            <div>
                <h1>BookStore</h1>
                <p>@TenantService.CurrentTenantName</p>
            </div>
        </div>

        <div class="layout-header-tools">
            <div class="menu-shell">
                <button class="btn btn-ghost" @onclick="HandleTenantMenuToggle" aria-haspopup="menu" aria-expanded="@_isTenantMenuOpen">Tenant</button>
                @if (_isTenantMenuOpen)
                {
                    <div class="menu-panel" role="menu">
                    @foreach (var tenant in TenantService.AvailableTenants)
                    {
                        <button class="menu-item" role="menuitem" @onclick="() => SwitchTenant(tenant.Id)">@tenant.Name</button>
                    }
                    </div>
                }
            </div>
            <BookStore.Web.Components.Shared.CurrencySelector/>
            <BookStore.Web.Components.Shared.ThemeSwitcher/>
            <LoginDisplay/>
        </div>
    </header>

    <div class="layout-content">
        <aside class="layout-sidebar @(_drawerOpen ? "is-open" : "is-closed")">
            <NavMenu/>
        </aside>

        <main class="layout-main">
            @Body
        </main>
    </div>
</div>

@inject CurrencyService CurrencyService
@inject TenantService TenantService
@inject NavigationManager Navigation
@inject ThemeService ThemeService
@inject IJSRuntime Js
@implements IDisposable

@code {
    bool _drawerOpen = true;
    bool _isTenantMenuOpen;

    void ToggleDrawer() => _drawerOpen = !_drawerOpen;

    void SwitchTenant(string tenantId)
    {
        Navigation.NavigateTo($"/?tenant={tenantId}", forceLoad: true);
    }

    protected override async Task OnInitializedAsync()
    {
        TenantService.OnChange += StateHasChanged;
        ThemeService.OnChange += HandleThemeChanged;
        await TenantService.InitializeAsync();
        await CurrencyService.InitializeAsync();
        await ThemeService.InitializeAsync();
        await ApplyThemeAsync();
    }

    private void HandleThemeChanged()
    {
        _ = ApplyThemeAsync();
    }

    private async Task ApplyThemeAsync()
    {
        var theme = ThemeService.CurrentTheme switch
        {
            ThemeMode.Light => "light",
            ThemeMode.Dark => "dark",
            _ => "auto"
        };

        await Js.InvokeVoidAsync("document.documentElement.setAttribute", "data-theme", theme);
    }

    private void HandleTenantMenuToggle()
    {
        _isTenantMenuOpen = !_isTenantMenuOpen;
    }

    public void Dispose()
    {
        TenantService.OnChange -= StateHasChanged;
        ThemeService.OnChange -= HandleThemeChanged;
    }

}
