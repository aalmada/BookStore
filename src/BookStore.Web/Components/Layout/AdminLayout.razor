            <strong>@TenantService.CurrentTenantName</strong>
            <span>Admin Console</span>
        </div>

        <nav aria-label="Admin navigation">
            <a href="/admin/books">Books</a>
            <a href="/admin/authors">Authors</a>
            <a href="/admin/categories">Categories</a>
